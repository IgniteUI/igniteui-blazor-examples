@page "/"

<div class="container">
    <h3>Filtering - Events</h3>
    <p>Demonstrates filtering events - OnFiltering (before) and OnFiltered (after). Check the log below for event details.</p>

    @if (users != null && columns != null)
    {
        <IgbGridLite TItem="User" 
                     Data="@users" 
                     Columns="@columns"
                     OnFiltering="@HandleFiltering"
                     OnFiltered="@HandleFiltered"
                     class="grid-lite-sample" />
    }

    <div class="event-log">
        <h4>Event Log:</h4>
        <div class="log-content">
            @foreach (var log in eventLogs.TakeLast(10))
            {
                <div class="log-entry">@log</div>
            }
        </div>
    </div>
</div>

@code {
    private List<User> users;
    private List<ColumnConfiguration<User>> columns;
    private List<string> eventLogs = new List<string>();

    protected override void OnInitialized()
    {
        // Generate 50 users
        users = MockDataGenerator.CreateUsers(50);

        columns = new List<ColumnConfiguration<User>>
        {
            new ColumnConfiguration<User>
            {
                Key = nameof(User.FirstName),
                HeaderText = "First name",
                Filter = true
            },
            new ColumnConfiguration<User>
            {
                Key = nameof(User.LastName),
                HeaderText = "Last name",
                Filter = true
            },
            new ColumnConfiguration<User>
            {
                Key = nameof(User.Age),
                HeaderText = "Age",
                Type = DataType.Number,
                Filter = true
            },
            new ColumnConfiguration<User>
            {
                Key = nameof(User.Active),
                HeaderText = "Active",
                Type = DataType.Boolean,
                Filter = true
            }
        };
    }

    private void HandleFiltering(IgbGridLiteFilteringEvent<User> e)
    {
        var log = $"[{DateTime.Now:HH:mm:ss}] OnFiltering - Column: {e.Expression?.Key}, Condition: {e.Expression?.Condition}, Term: {e.Expression?.SearchTerm}";
        eventLogs.Add(log);
        StateHasChanged();
    }

    private void HandleFiltered(IgbGridLiteFilteredEvent<User> e)
    {
        var log = $"[{DateTime.Now:HH:mm:ss}] OnFiltered - Filter applied successfully";
        eventLogs.Add(log);
        StateHasChanged();
    }
}
