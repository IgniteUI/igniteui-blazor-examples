@page "/"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using IgniteUI.Blazor.Controls

<div class="container">
    <h3>Sorting - Events</h3>
    <p>Demonstrates sorting events - OnSorting (before) and OnSorted (after). Click column headers to sort and check the log below.</p>

    @if (products != null && columns != null)
    {
        <IgbGridLite TItem="ProductInfo" 
                     Data="@products" 
                     Columns="@columns"
                     OnSorting="@HandleSorting"
                     OnSorted="@HandleSorted"
                     class="grid-lite-sample" />
    }

    <div class="event-log">
        <h4>Event Log:</h4>
        <div class="log-content">
            @foreach (var log in eventLogs.TakeLast(10))
            {
                <div class="log-entry">@log</div>
            }
        </div>
    </div>
</div>

@code {
    private List<ProductInfo> products;
    private List<ColumnConfiguration<ProductInfo>> columns;
    private List<string> eventLogs = new List<string>();

    protected override void OnInitialized()
    {
        products = MockDataGenerator.CreateProducts(50);

        columns = new List<ColumnConfiguration<ProductInfo>>
        {
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Name),
                HeaderText = "Product Name",
                Type = DataType.String,
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Price),
                HeaderText = "Price",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Sold),
                HeaderText = "Units sold",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Total),
                HeaderText = "Total sold",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Rating),
                HeaderText = "Customer rating",
                Type = DataType.Number,
                Width = "180px",
                Sort = true
            }
        };
    }

    private void HandleSorting(IgbGridLiteSortingEvent e)
    {
        var log = $"[{DateTime.Now:HH:mm:ss}] OnSorting - Column: {e.Expression?.Key}, Direction: {e.Expression?.Direction}";
        eventLogs.Add(log);
        StateHasChanged();
    }

    private void HandleSorted(IgbGridLiteSortedEvent e)
    {
        var log = $"[{DateTime.Now:HH:mm:ss}] OnSorted - Sort applied successfully";
        eventLogs.Add(log);
        StateHasChanged();
    }
}
