@page "/"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using IgniteUI.Blazor.Controls

<div class="container">
    <h3>Sorting - Grid Configuration</h3>
    <p>Grid-level sort configuration with multi-column sorting and tri-state enabled.</p>

    @if (products != null && columns != null)
    {
        <IgbGridLite TItem="ProductInfo" 
                     Data="@products" 
                     Columns="@columns"
                     SortConfiguration="@sortConfig"
                     class="grid-lite-sample" />
    }
</div>

@code {
    private List<ProductInfo> products;
    private List<ColumnConfiguration<ProductInfo>> columns;
    private GridSortConfiguration sortConfig;

    protected override void OnInitialized()
    {
        products = MockDataGenerator.CreateProducts(50);

        // Grid-level sort configuration
        sortConfig = new GridSortConfiguration
        {
            Multiple = true,  // Enable multi-column sorting
            TriState = true   // Enable tri-state sorting (asc -> desc -> none)
        };

        columns = new List<ColumnConfiguration<ProductInfo>>
        {
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Name),
                HeaderText = "Product Name",
                Type = DataType.String,
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Price),
                HeaderText = "Price",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Sold),
                HeaderText = "Units sold",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Total),
                HeaderText = "Total sold",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Rating),
                HeaderText = "Customer rating",
                Type = DataType.Number,
                Width = "180px",
                Sort = true
            }
        };
    }
}
