@page "/"

<div class="container">
    <h3>Styling - Themes</h3>
    <p>Switch between different GridLite themes. Select a theme from the dropdown below.</p>

    <div class="theme-selector">
        <label>Theme: </label>
        <select @onchange="ChangeTheme" class="theme-dropdown">
            <option value="light/bootstrap">Light Bootstrap</option>
            <option value="light/material">Light Material</option>
            <option value="light/fluent">Light Fluent</option>
            <option value="light/indigo">Light Indigo</option>
            <option value="dark/bootstrap">Dark Bootstrap</option>
            <option value="dark/material">Dark Material</option>
            <option value="dark/fluent">Dark Fluent</option>
            <option value="dark/indigo">Dark Indigo</option>
        </select>
    </div>

    @if (products != null && columns != null)
    {
        <IgbGridLite TItem="ProductInfo" 
                     Data="@products" 
                     Columns="@columns"
                     class="grid-lite-sample" />
    }
</div>

@code {
    private List<ProductInfo> products;
    private List<ColumnConfiguration<ProductInfo>> columns;
    private string currentTheme = "light/bootstrap";

    protected override void OnInitialized()
    {
        products = MockDataGenerator.CreateProducts(50);

        columns = new List<ColumnConfiguration<ProductInfo>>
        {
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Name),
                HeaderText = "Product Name",
                Type = DataType.String,
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Price),
                HeaderText = "Price",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Sold),
                HeaderText = "Units sold",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Total),
                HeaderText = "Total sold",
                Type = DataType.Number,
                Width = "150px",
                Sort = true
            },
            new ColumnConfiguration<ProductInfo>
            {
                Key = nameof(ProductInfo.Rating),
                HeaderText = "Customer rating",
                Type = DataType.Number,
                Width = "180px",
                Sort = true
            }
        };
    }

    private void ChangeTheme(ChangeEventArgs e)
    {
        currentTheme = e.Value?.ToString() ?? "light/bootstrap";
        // Note: In a real implementation, you would dynamically load the theme CSS
        // For this sample, the theme would need to be changed via JavaScript
    }
}
