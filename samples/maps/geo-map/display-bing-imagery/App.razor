@using IgniteUI.Blazor.Controls
@inject NavigationManager NavManager

<style>
    igc-dialog::part(content) {
        width: 700px;
    }
</style>

<!-- UI controls -->
<div class="map-controls" style="display:flex; justify-content:center; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">
    <IgbButton @onclick="ShowDialog" Variant=@ButtonVariant.Contained>
        Enter Bing Maps Enterprise Key
    </IgbButton>

    <IgbPropertyEditorPanel Name="editor" @ref="editor"
                            IsHorizontal="true"
                            IsWrappingEnabled="false">
    </IgbPropertyEditorPanel>
</div>


<!-- DIALOG (always rendered, like Azure) -->
<IgbDialog @ref="DialogRef"
           Title="Enterise Key:"
           CloseOnOutsideClick="false"
           Closed="OnDialogClosed">

    <form method="dialog">
        <p style="font-size:0.9rem; margin-bottom:0.75rem;">
            Bing Maps Basic has been retired, we encourage you to migrate to Azure Maps.  
            If you have a Bing Maps Enterprise key, you may continue to use Bing Maps.
            For more information, visit:<br />
            <a href="https://learn.microsoft.com/en-us/bingmaps/getting-started/bing-maps-dev-center-help/getting-a-bing-maps-key"
               target="_blank">
               Bing Maps Key Documentation
            </a>
        </p>

        <IgbInput Label="Enterprise Key"
                  @bind-value="BingKey" />
    </form>
</IgbDialog>


<!-- MAP (always rendered, like Azure) -->
<IgbGeographicMap @ref="BingMap"
                  Height="100%"
                  Width="100%"
                  Zoomable="true"
                  BackgroundContent="@BingBackground">

    <IgbGeographicTileSeries @ref="TileSeries" />
</IgbGeographicMap>


@code {
    private string BingKey;
    private bool _dialogShown;

    private IgbDialog DialogRef;
    private IgbPropertyEditorPanel editor;

    private IgbGeographicMap BingMap;
    private IgbGeographicTileSeries TileSeries;

    private IgbBingMapsMapImagery BingBackground;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            // set editor target
            editor.Target = BingMap;

            await Task.Delay(1000); // allow Blazor to complete rendering

            // must queue AFTER render
            await InvokeAsync(async () =>
            {
                await DialogRef.ShowAsync();
            });
        }
    }

    private async Task ShowDialog()
    {
        await DialogRef.ShowAsync();
    }

    private void OnDialogClosed(IgbVoidEventArgs e)
    {
        if (!string.IsNullOrWhiteSpace(BingKey))
        {
            ApplyBingImagery();
        }
        StateHasChanged();
    }

    private void ApplyBingImagery()
    {
        // Create Bing background imagery for map
        BingBackground = new IgbBingMapsMapImagery
        {
            ApiKey = BingKey,
            ImageryStyle = BingMapsImageryStyle.Aerial
        };

        // Set tile series imagery
        TileSeries.TileImagery = BingBackground;

        // Optional: Zoom to US
        var rect = new Rect(-124.77, 24.52, new Size(59, 25));
        BingMap.ZoomToGeographic(rect);
    }
}
